{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Materials Research Experiment Event",
  "description": "A completed materials research experiment submitted for lakehouse ingestion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "occurred_at",
    "source_system",
    "experiment"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "const": "experiment.completed"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_system": {
      "type": "string",
      "minLength": 1
    },
    "experiment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiment_id",
        "program_id",
        "lab_id",
        "material",
        "process_conditions",
        "measurements"
      ],
      "properties": {
        "experiment_id": {
          "type": "string",
          "minLength": 1
        },
        "program_id": {
          "type": "string",
          "minLength": 1
        },
        "lab_id": {
          "type": "string",
          "minLength": 1
        },
        "material": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "material_id",
            "family",
            "composition"
          ],
          "properties": {
            "material_id": {
              "type": "string",
              "minLength": 1
            },
            "family": {
              "type": "string",
              "minLength": 1
            },
            "composition": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "component",
                  "mass_percent"
                ],
                "properties": {
                  "component": {
                    "type": "string",
                    "minLength": 1
                  },
                  "mass_percent": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100
                  }
                }
              }
            }
          }
        },
        "process_conditions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "temperature_c",
            "pressure_mpa",
            "duration_minutes"
          ],
          "properties": {
            "temperature_c": {
              "type": "number",
              "minimum": -273.15
            },
            "pressure_mpa": {
              "type": "number",
              "minimum": 0
            },
            "duration_minutes": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "measurements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tensile_strength_mpa",
            "conductivity_s_per_m",
            "density_g_per_cm3"
          ],
          "properties": {
            "tensile_strength_mpa": {
              "type": "number",
              "minimum": 0
            },
            "conductivity_s_per_m": {
              "type": "number",
              "minimum": 0
            },
            "density_g_per_cm3": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        }
      }
    }
  }
}
